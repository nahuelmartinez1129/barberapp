// Schema de la base de datos para BarberApp
// Multi-tenant: cada Barberia es un "tenant" independiente

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= TENANT =============

model Barberia {
  id          String  @id @default(cuid())
  nombre      String
  slug        String  @unique // usado en la url publica: /reservar/[slug]
  telefono    String?
  direccion   String?
  logoUrl     String?
  zonaHoraria String  @default("America/Argentina/Buenos_Aires")

  horariosConfigurados Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  miembros    MiembroBarberia[]
  servicios   Servicio[]
  turnos      Turno[]
  suscripcion Suscripcion?
  horarios    HorarioBarberia[]
  clientes    Cliente[]

  @@map("barberias")
}

// ============= USUARIOS Y ROLES =============

enum RolGlobal {
  SUPER_ADMIN // vos, gestionando la plataforma
  USUARIO
}

enum RolBarberia {
  DUENO
  BARBERO
}

model Usuario {
  id           String    @id @default(cuid())
  nombre       String
  email        String    @unique
  passwordHash String
  telefono     String?
  rolGlobal    RolGlobal @default(USUARIO)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Usuario es exclusivamente para roles autenticados via NextAuth:
  // DUENO y BARBERO. Los clientes finales NO son Usuario (ver modelo
  // Cliente más abajo) — no requieren login ni password.
  membresias MiembroBarberia[]

  @@map("usuarios")
}

// Tabla puente: un usuario puede ser dueño/barbero de UNA barberia
// y a la vez cliente de OTRAS barberias (por eso es muchos a muchos)
model MiembroBarberia {
  id          String      @id @default(cuid())
  barberiaId  String
  usuarioId   String
  rol         RolBarberia
  activo      Boolean     @default(true)
  // Solo relevante si rol = BARBERO
  colorAgenda String?     @default("#3b82f6")
  createdAt   DateTime    @default(now())

  barberia Barberia @relation(fields: [barberiaId], references: [id], onDelete: Cascade)
  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  serviciosAsignados BarberoServicio[]
  turnosComoBarbero  Turno[]           @relation("TurnosBarbero")

  @@unique([barberiaId, usuarioId])
  @@map("miembros_barberia")
}

// ============= SERVICIOS =============

model Servicio {
  id              String   @id @default(cuid())
  barberiaId      String
  nombre          String
  descripcion     String?
  precio          Decimal  @db.Decimal(10, 2)
  duracionMinutos Int
  activo          Boolean  @default(true)
  orden           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  barberia          Barberia          @relation(fields: [barberiaId], references: [id], onDelete: Cascade)
  barberosAsignados BarberoServicio[]
  turnos            Turno[]

  @@map("servicios")
}

// Tabla puente: que barbero puede realizar que servicio
model BarberoServicio {
  id         String @id @default(cuid())
  barberoId  String // referencia a MiembroBarberia.id (donde rol = BARBERO)
  servicioId String

  barbero  MiembroBarberia @relation(fields: [barberoId], references: [id], onDelete: Cascade)
  servicio Servicio        @relation(fields: [servicioId], references: [id], onDelete: Cascade)

  @@unique([barberoId, servicioId])
  @@map("barbero_servicios")
}

// ============= CLIENTES (sin autenticacion) =============

// Un Cliente NO es un Usuario: no tiene password, no inicia sesion, no
// pasa por NextAuth. Se identifica de forma unica dentro de cada
// barberia por su telefono. Si el mismo telefono reserva de nuevo en la
// misma barberia, se reutiliza el mismo registro (acumula historial);
// si reserva en OTRA barberia, se crea un Cliente distinto, porque cada
// barberia es un tenant independiente.
model Cliente {
  id            String   @id @default(cuid())
  barberiaId    String
  nombre        String
  telefono      String
  email         String?
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  barberia Barberia @relation(fields: [barberiaId], references: [id], onDelete: Cascade)
  turnos   Turno[]  @relation("TurnosCliente")

  @@unique([barberiaId, telefono])
  @@map("clientes")
}

// ============= TURNOS =============

enum EstadoTurno {
  PENDIENTE
  CONFIRMADO
  COMPLETADO
  CANCELADO
  NO_ASISTIO
}

model Turno {
  id            String      @id @default(cuid())
  barberiaId    String
  barberoId     String // MiembroBarberia.id
  clienteId     String // Cliente.id (NO Usuario - los clientes no se autentican)
  servicioId    String
  fecha         DateTime    @db.Date
  horaInicio    String // formato "HH:mm"
  horaFin       String // formato "HH:mm"
  estado        EstadoTurno @default(PENDIENTE)
  precioCobrado Decimal     @db.Decimal(10, 2)
  notas         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  barberia Barberia        @relation(fields: [barberiaId], references: [id], onDelete: Cascade)
  barbero  MiembroBarberia @relation("TurnosBarbero", fields: [barberoId], references: [id])
  cliente  Cliente         @relation("TurnosCliente", fields: [clienteId], references: [id])
  servicio Servicio        @relation(fields: [servicioId], references: [id])

  @@index([barberiaId, fecha])
  @@index([barberoId, fecha])
  @@map("turnos")
}

// Bloqueos de horario del barbero (vacaciones, almuerzo, etc.)
model BloqueoHorario {
  id         String   @id @default(cuid())
  barberoId  String
  fecha      DateTime @db.Date
  horaInicio String
  horaFin    String
  motivo     String?
  createdAt  DateTime @default(now())

  @@index([barberoId, fecha])
  @@map("bloqueos_horario")
}

// Horario habitual de atencion del barbero por dia de semana
model HorarioAtencion {
  id         String  @id @default(cuid())
  barberoId  String
  diaSemana  Int // 0 = domingo, 6 = sabado
  horaInicio String
  horaFin    String
  activo     Boolean @default(true)

  @@unique([barberoId, diaSemana])
  @@map("horarios_atencion")
}

// Horario general de atencion de la BARBERIA (no del barbero individual).
// Actua como restriccion adicional: un turno solo es valido si cae dentro
// del horario de la barberia Y dentro del horario del barbero asignado.
// Un registro por dia de la semana (0 = domingo, 6 = sabado).
model HorarioBarberia {
  id         String  @id @default(cuid())
  barberiaId String
  diaSemana  Int // 0 = domingo, 6 = sabado
  activo     Boolean @default(true)
  horaInicio String // formato "HH:mm"
  horaFin    String // formato "HH:mm"

  barberia Barberia @relation(fields: [barberiaId], references: [id], onDelete: Cascade)

  @@unique([barberiaId, diaSemana])
  @@map("horarios_barberia")
}

// ============= SUSCRIPCION (SaaS) =============

enum PlanSuscripcion {
  BASICO
  PRO
  PREMIUM
}

enum EstadoSuscripcion {
  ACTIVA
  VENCIDA
  CANCELADA
  PRUEBA
}

model Suscripcion {
  id                        String            @id @default(cuid())
  barberiaId                String            @unique
  plan                      PlanSuscripcion   @default(BASICO)
  estado                    EstadoSuscripcion @default(PRUEBA)
  precioMensual             Decimal           @db.Decimal(10, 2)
  fechaInicio               DateTime          @default(now())
  fechaProximoPago          DateTime
  cancelarAlFinalDelPeriodo Boolean           @default(false)
 mercadopagoSubId String? @unique // id de la suscripción en Mercado Pago
  checkoutUrl              String?

  fechaUltimaSincronizacion DateTime?

  ultimaRespuestaMP        Json?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  barberia Barberia          @relation(fields: [barberiaId], references: [id], onDelete: Cascade)
  pagos    PagoSuscripcion[]

  @@map("suscripciones")
}

enum EstadoPago {
  PENDIENTE
  APROBADO
  RECHAZADO
  REEMBOLSADO
}

model PagoSuscripcion {
  id String @id @default(cuid())

  suscripcionId String

  monto Decimal @db.Decimal(10, 2)

  moneda String @default("ARS")

  estado EstadoPago

  mercadopagoId String?

  descripcion String?

  fechaPago DateTime @default(now())

  createdAt DateTime @default(now())

  suscripcion Suscripcion @relation(fields: [suscripcionId], references: [id], onDelete: Cascade)

  @@index([suscripcionId])
  @@map("pagos_suscripcion")
}

model ConfiguracionSistema {
  id String @id @default(cuid())

  planBasicoMercadoPagoId String?
  planProMercadoPagoId String?
  planPremiumMercadoPagoId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("configuracion_sistema")
}